{
  "name": "pay-and-pray-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --configLoader runner --host 0.0.0.0 --port 3000",
    "build": "tsc -b && vite build --configLoader runner",
    "start": "vite preview --configLoader runner --host 0.0.0.0 --port 3000",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "cy:run": "node scripts/cypress-run.mjs",
    "cy:open": "cypress open",
    "e2e:stack": "cd .. && docker compose up db backend",
    "e2e:vite:build": "cross-env VITE_API_URL=http://localhost:8080 vite build --configLoader runner",
    "e2e:vite:start": "vite preview --configLoader runner --host 0.0.0.0 --port 3000",
    "e2e": "npm run e2e:vite:build && cross-env WAIT_ON_TIMEOUT=180000 start-server-and-test \"npm run e2e:stack\" tcp:8080 \"npm run e2e:vite:start\" http-get://localhost:3000 cy:run",
    "e2e:open": "npm run e2e:vite:build && cross-env WAIT_ON_TIMEOUT=180000 start-server-and-test \"npm run e2e:stack\" tcp:8080 \"npm run e2e:vite:start\" http-get://localhost:3000 cy:open",
    "mobile:build": "npm run build && cap sync",
    "mobile:android": "npm run build && cap run android",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "lucide-react": "^1.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "cypress": "^15.15.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.7"
  }
}
