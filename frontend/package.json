{
  "name": "pay-and-pray-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "cy:run": "node scripts/cypress-run.mjs",
    "cy:open": "cypress open",
    "e2e:stack": "cd .. && docker compose up db backend",
    "e2e:next:build": "cross-env NEXT_PUBLIC_API_URL=http://localhost:8080 next build",
    "e2e:next:start": "next start",
    "e2e": "npm run e2e:next:build && cross-env WAIT_ON_TIMEOUT=180000 start-server-and-test \"npm run e2e:stack\" tcp:8080 \"npm run e2e:next:start\" http-get://localhost:3000 cy:run",
    "e2e:open": "npm run e2e:next:build && cross-env WAIT_ON_TIMEOUT=180000 start-server-and-test \"npm run e2e:stack\" tcp:8080 \"npm run e2e:next:start\" http-get://localhost:3000 cy:open"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "cypress": "^15.15.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
